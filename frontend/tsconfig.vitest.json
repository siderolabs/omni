{
  "extends": "./tsconfig.app.json",
  "include": [
    "vitest.setup.*",
    "msw/**/*",
    "src/**/*.spec.*",
    "src/types/**/*",
    "env.d.ts",
    "typed-router.d.ts"
  ],
  "exclude": ["src/**/*.stories.*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",

    "paths": {
      "@/*": ["./src/*"],
      "@msw/*": ["./msw/*"]
    }
  }
}
